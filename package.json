{
  "name": "mqttmountain",
  "version": "1.0.22",
  "description": "高性能 MQTT 客户端（Electron + Vue 3 + TS）",
  "main": "dist-electron/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:dir": "vue-tsc --noEmit && vite build && electron-builder --dir",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "jszip": "^3.10.1",
    "mqtt": "^5.15.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.2.12"
  },
  "build": {
    "appId": "com.mountain.mqtt",
    "productName": "MQTTMountain",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    }
  }
}
